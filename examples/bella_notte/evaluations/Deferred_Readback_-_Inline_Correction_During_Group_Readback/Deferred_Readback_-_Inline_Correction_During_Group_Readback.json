          {
            "expectation": {
              "note": "Check_Group_Readback_Corrected_Name_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {
                    "guest_name": "Wong"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
