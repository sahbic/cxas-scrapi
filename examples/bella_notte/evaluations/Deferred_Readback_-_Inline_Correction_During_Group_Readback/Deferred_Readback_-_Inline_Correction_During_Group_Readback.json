{
  "name": "ad7aec14-7ffa-4549-aeec-b94d4780c29a",
  "displayName": "Deferred Readback - Inline Correction During Group Readback",
  "description": "User provides name (deferred), then corrects it before providing special requests. The correction overwrites the deferred value. When special requests are provided, group readback fires with the corrected name. Verifies that deferred values can be corrected before group completion.",
  "tags": [
    "slot-machine",
    "readback",
    "deferred-readback",
    "group-readback",
    "correction",
    "edge-case"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "Table for 2 on June 17th"
            }
          },
          {
            "expectation": {
              "note": "Check_set_reservation_basics_Called",
              "toolCall": {
                "tool": "set_reservation_basics",
                "args": {
                  "party_size": 2.0,
                  "preferred_date": "2026-06-17"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_PartySize_And_Date_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {
                    "party_size": 2
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          },
          {
            "expectation": {
              "note": "Check_PartySize_And_Date_Confirmed",
              "updatedVariables": {
                "sm": {
                  "filled": {
                    "party_size": 2
                  },
                  "status": "in_progress"
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "6 PM please"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSelectedTime_Called",
              "toolCall": {
                "tool": "set_selected_time"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Time_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {}
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "The name is Wang"
            }
          },
          {
            "expectation": {
              "note": "Check_SetGuestName_Called",
              "toolCall": {
                "tool": "set_guest_info",
                "args": {
                  "guest_name": "Wang"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Name_Deferred_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {
                    "guest_name": "Wang"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Wait, actually the name is Wong not Wang"
            }
          },
          {
            "expectation": {
              "note": "Check_SetGuestName_Corrected",
              "toolCall": {
                "tool": "set_guest_info",
                "args": {
                  "guest_name": "Wong"
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "No special requests"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSpecialRequests_Called",
              "toolCall": {
                "tool": "set_guest_info"
              }
            }
