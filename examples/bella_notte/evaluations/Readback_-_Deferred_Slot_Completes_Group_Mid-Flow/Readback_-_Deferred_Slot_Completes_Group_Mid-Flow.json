{
  "name": "f3729f2a-474a-43e5-b5c6-0f36bd371836",
  "displayName": "Readback - Deferred Slot Completes Group Mid-Flow",
  "description": "User provides party size, date, and name in one message. Immediate readback fires for party size and date only — name is deferred (BookReservation has readback_inputs: True). User confirms size+date, FindAvailableTimes fires, user picks time, confirms time. Then user provides special requests. Since all deferred-group inputs are now accounted for, a combined readback fires for name + requests. Verifies that mixed immediate + deferred slots in one message are handled correctly.",
  "tags": ["slot-machine", "readback", "deferred-readback", "group-readback", "multi-slot", "edge-case"],
  "golden": {
    "turns": [{
      "steps": [{
        "userInput": {
          "text": "Hi I'd like to book a table for my wife and I on June 17. My name is John Smith"
        }
      }, {
        "expectation": {
          "note": "Check_SetPartySize_Called",
          "toolCall": {
            "tool": "set_party_size",
            "args": {
              "size": 2.0
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_SetPreferredDate_Called",
          "toolCall": {
            "tool": "set_preferred_date",
            "args": {
              "date": "2026-06-17"
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_SetGuestName_Called",
          "toolCall": {
            "tool": "set_guest_name",
            "args": {
              "name": "John Smith"
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_Immediate_Readback_For_Size_And_Date_Only",
          "agentResponse": {
            "chunks": [{
              "text": "2"
            }]
          }
        }
      }, {
        "expectation": {
          "note": "Check_Date_In_Readback",
          "agentResponse": {
            "chunks": [{
              "text": "June"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes that's correct"
        }
      }, {
        "expectation": {
          "note": "Check_Times_Shown",
          "agentResponse": {
            "chunks": [{
              "text": "PM"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "7:30 PM"
        }
      }, {
        "expectation": {
          "note": "Check_SetSelectedTime_Called",
          "toolCall": {
            "tool": "set_selected_time"
          }
        }
      }, {
        "expectation": {
          "note": "Check_Readback_Time",
          "agentResponse": {
            "chunks": [{
              "text": "7:30"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes"
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "My wife has a shellfish allergy, please make a note"
        }
      }, {
        "expectation": {
          "note": "Check_SetSpecialRequests_Called",
          "toolCall": {
            "tool": "set_special_requests"
          }
        }
      }, {
        "expectation": {
          "note": "Check_Group_Readback_Name",
          "agentResponse": {
            "chunks": [{
              "text": "Smith"
            }]
          }
        }
      }, {
        "expectation": {
          "note": "Check_Group_Readback_Allergy",
          "agentResponse": {
            "chunks": [{
              "text": "shellfish"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes, that's right"
        }
      }, {
        "expectation": {
          "note": "Check_Booking_Confirmed",
          "agentResponse": {
            "chunks": [{
              "text": "BN-"
            }]
          }
        }
      }]
    }],
    "evaluationExpectations": ["No Technical Leakage", "Warm Restaurant Host Persona"]
  }
}
