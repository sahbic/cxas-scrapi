{
  "name": "a0674202-ddba-479f-a889-1a131884eb33",
  "displayName": "Party Size Variations - Natural Language Numbers",
  "description": "Tests that the agent correctly parses natural language numbers into proper party sizes, then reads back for confirmation.",
  "tags": [
    "slot-machine",
    "parsing",
    "readback",
    "party-size"
  ],
  "evaluationDatasets": [
    "Bella Notte Slot Machine - Full Suite"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "It'll be just me and my wife"
            }
          },
          {
            "expectation": {
              "note": "Check_Parses_Two_People",
              "toolCall": {
                "tool": "set_party_size",
                "args": {
                  "size": 2.0
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Readback_PartySize",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "2"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes, that's right"
            }
          },
          {
            "expectation": {
              "note": "Check_Asks_For_Date",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "date"
                  }
                ]
              }
            }
          }
        ]
      }
    ],
    "evaluationExpectations": [
      "Warm Restaurant Host Persona",
      "No Technical Leakage"
    ]
  }
