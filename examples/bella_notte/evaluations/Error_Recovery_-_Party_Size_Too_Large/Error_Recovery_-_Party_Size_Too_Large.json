{
  "name": "a98f4684-f24f-4378-bd16-8cf3494b20f5",
  "displayName": "Error Recovery - Party Size Too Large",
  "description": "User requests party of 15 (exceeds max 8). Agent should call set_party_size, get error, and direct user to events team. Then recover when user provides valid size, readback, and confirm.",
  "tags": [
    "slot-machine",
    "error-handling",
    "readback",
    "validation"
  ],
  "evaluationDatasets": [
    "Bella Notte Slot Machine - Full Suite"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "I need a table for 15 people"
            }
          },
          {
            "expectation": {
              "note": "Check_SetPartySize_Called_With_15",
              "toolCall": {
                "tool": "set_party_size",
                "args": {
                  "size": 15.0
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Events_Team_Redirect",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "events@bellanotte.com"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Oh wait, it's actually just 4 of us"
            }
          },
          {
            "expectation": {
              "note": "Check_SetPartySize_Called_With_4",
              "toolCall": {
                "tool": "set_party_size",
                "args": {
                  "size": 4.0
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Readback_PartySize",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "4"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes, that's correct"
            }
          },
          {
            "expectation": {
              "note": "Check_Asks_For_Date_After_Recovery",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "date"
                  }
                ]
              }
            }
          }
        ]
      }
    ]
  }
}
