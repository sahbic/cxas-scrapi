            }
          },
          {
            "expectation": {
              "note": "Check_SetSpecialRequests_Called",
              "toolCall": {
                "tool": "set_special_requests"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Readback_Requests",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "birthday"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
