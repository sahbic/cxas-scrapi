{
  "name": "d18b89d2-d0b9-48f2-b32d-8d18cf313724",
  "displayName": "Multi-Slot - Three Fields in One Message",
  "description": "User provides party size, date, AND name in a single message. All three setter tools must fire, then batched readback of all three values, then confirm_pending commits all.",
  "tags": [
    "slot-machine",
    "multi-slot",
    "readback",
    "parallel-tools",
    "critical"
  ],
  "evaluationDatasets": [
    "Bella Notte Slot Machine - Full Suite"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "I'd like to book a table for 2 on June 20th under the name Johnson"
            }
          },
          {
            "expectation": {
              "note": "Check_SetPartySize_Called",
              "toolCall": {
                "tool": "set_party_size",
                "args": {
                  "size": 2.0
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_SetPreferredDate_Called",
              "toolCall": {
                "tool": "set_preferred_date",
                "args": {
                  "date": "2026-06-20"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_SetGuestName_Called",
              "toolCall": {
                "tool": "set_guest_name",
                "args": {
                  "name": "Johnson"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Readback_All_Three",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "Johnson"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes, that's correct"
            }
          },
          {
            "expectation": {
              "note": "Check_AvailableTimes_Presented",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "6:00 PM"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "6 PM works"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSelectedTime_Called",
              "toolCall": {
                "tool": "set_selected_time"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Readback_Time",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "6"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          },
          {
            "expectation": {
              "note": "Check_Asks_For_Requests",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "special"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
