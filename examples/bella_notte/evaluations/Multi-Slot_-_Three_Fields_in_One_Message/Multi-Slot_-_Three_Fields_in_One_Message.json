{
  "name": "d18b89d2-d0b9-48f2-b32d-8d18cf313724",
  "displayName": "Multi-Slot - Three Fields in One Message",
  "description": "User provides party size, date, AND name in a single message. Multi-slot setters fire (set_reservation_basics with both, set_guest_info with name), then batched readback of all three values, then confirm_pending commits all.",
  "tags": [
    "slot-machine",
    "multi-slot",
    "readback",
    "critical"
  ],
  "evaluationDatasets": [
    "Bella Notte Slot Machine - Full Suite"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "I'd like to book a table for 2 on June 20th under the name Johnson"
            }
          },
          {
            "expectation": {
              "note": "Check_SetReservationBasics_Called_With_Both",
              "toolCall": {
                "tool": "set_reservation_basics",
                "args": {
                  "party_size": 2.0,
                  "preferred_date": "2026-06-20"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_SetGuestName_Called",
              "toolCall": {
                "tool": "set_guest_info",
                "args": {
                  "guest_name": "Johnson"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_All_Three_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {
                    "party_size": 2,
                    "preferred_date": "2026-06-20"
                  },
                  "deferred": {
                    "guest_name": "Johnson"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes, that's correct"
            }
          },
          {
            "expectation": {
              "note": "Check_All_Three_Confirmed",
              "updatedVariables": {
                "sm": {
                  "filled": {
                    "party_size": 2,
                    "preferred_date": "2026-06-20"
                  },
                  "deferred": {
                    "guest_name": "Johnson"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "6 PM works"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSelectedTime_Called",
              "toolCall": {
                "tool": "set_selected_time"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Time_Pending",
              "updatedVariables": {
                "sm": {
                  "pending": {
                    "selected_time": "18:00"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          },
          {
            "expectation": {
              "note": "Check_Time_Confirmed",
              "updatedVariables": {
                "sm": {
                  "filled": {
                    "selected_time": "18:00"
                  }
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "We're celebrating a birthday, could you add some candles?"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSpecialRequests_Called",
              "toolCall": {
                "tool": "set_guest_info"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Time_Still_Filled",
              "updatedVariables": {
                "sm": {
                  "filled": {
                    "selected_time": "18:00"
                  },
                  "status": "in_progress"
                }
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          },
          {
            "expectation": {
              "note": "Check_Booking_Complete",
              "updatedVariables": {
                "sm": {
