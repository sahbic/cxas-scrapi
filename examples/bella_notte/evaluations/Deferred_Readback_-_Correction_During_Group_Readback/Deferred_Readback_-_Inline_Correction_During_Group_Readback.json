{
  "name": "ad7aec14-7ffa-4549-aeec-b94d4780c29a",
  "displayName": "Deferred Readback - Inline Correction During Group Readback",
  "description": "User provides name (deferred), then corrects it before providing special requests. The correction overwrites the deferred value. When special requests are provided, group readback fires with the corrected name. Verifies that deferred values can be corrected before group completion.",
  "tags": ["slot-machine", "readback", "deferred-readback", "group-readback", "correction", "edge-case"],
  "golden": {
    "turns": [{
      "steps": [{
        "userInput": {
          "text": "Table for 2 on June 17th"
        }
      }, {
        "expectation": {
          "note": "Check_SetPartySize_Called",
          "toolCall": {
            "tool": "set_party_size",
            "args": {
              "size": 2.0
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_SetPreferredDate_Called",
          "toolCall": {
            "tool": "set_preferred_date",
            "args": {
              "date": "2026-06-17"
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_Readback_Size_Date",
          "agentResponse": {
            "chunks": [{
              "text": "2"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes"
        }
      }, {
        "expectation": {
          "note": "Check_Times_Shown",
          "agentResponse": {
            "chunks": [{
              "text": "PM"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "6 PM please"
        }
      }, {
        "expectation": {
          "note": "Check_SetSelectedTime_Called",
          "toolCall": {
            "tool": "set_selected_time"
          }
        }
      }, {
        "expectation": {
          "note": "Check_Readback_Time",
          "agentResponse": {
            "chunks": [{
              "text": "6"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes"
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "The name is Wang"
        }
      }, {
        "expectation": {
          "note": "Check_SetGuestName_Called",
          "toolCall": {
            "tool": "set_guest_name",
            "args": {
              "name": "Wang"
            }
          }
        }
      }, {
        "expectation": {
          "note": "Check_No_Readback_Asks_For_Requests",
          "agentResponse": {
            "chunks": [{
              "text": "special"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Wait, actually the name is Wong not Wang"
        }
      }, {
        "expectation": {
          "note": "Check_SetGuestName_Corrected",
          "toolCall": {
            "tool": "set_guest_name",
            "args": {
              "name": "Wong"
            }
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "No special requests"
        }
      }, {
        "expectation": {
          "note": "Check_SetSpecialRequests_Called",
          "toolCall": {
            "tool": "set_special_requests"
          }
        }
      }, {
        "expectation": {
          "note": "Check_Group_Readback_Corrected_Name",
          "agentResponse": {
            "chunks": [{
              "text": "Wong"
            }]
          }
        }
      }]
    }, {
      "steps": [{
        "userInput": {
          "text": "Yes, that's right"
        }
      }, {
        "expectation": {
          "note": "Check_Booking_Confirmed",
          "agentResponse": {
            "chunks": [{
              "text": "BN-"
            }]
          }
        }
      }]
    }],
    "evaluationExpectations": ["Warm Restaurant Host Persona", "No Technical Leakage"]
  }
}
