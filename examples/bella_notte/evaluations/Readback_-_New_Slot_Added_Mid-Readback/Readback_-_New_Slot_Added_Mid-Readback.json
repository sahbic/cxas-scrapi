{
  "displayName": "Readback - New Slot Added Mid-Readback",
  "description": "User provides name, date, and party size in one message. Name is deferred (BookReservation input), so readback covers only party size and date. User then adds special requests — completing the deferred group (name + requests). Since the confirm also fires FindAvailableTimes, the executor takes priority. On the next turn (time selection), all pending values (time + name + requests) are read back together. Verifies that deferred values accumulate correctly and surface in the combined readback.",
  "tags": [
    "slot-machine",
    "readback",
    "deferred-readback",
    "fresh-pending",
    "multi-slot",
    "edge-case"
  ],
  "evaluationDatasets": [
    "Bella Notte Slot Machine - Full Suite"
  ],
  "golden": {
    "turns": [
      {
        "steps": [
          {
            "userInput": {
              "text": "Hi I'd like to book a table for my wife and I on June 17 for our anniversary. My name is John Smith"
            }
          },
          {
            "expectation": {
              "note": "Check_SetPartySize_Called",
              "toolCall": {
                "tool": "set_party_size",
                "args": {
                  "size": 2.0
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_SetPreferredDate_Called",
              "toolCall": {
                "tool": "set_preferred_date",
                "args": {
                  "date": "2026-06-17"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_SetGuestName_Called",
              "toolCall": {
                "tool": "set_guest_name",
                "args": {
                  "name": "John Smith"
                }
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Immediate_Readback_Size_And_Date_Only",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "2"
                  }
                ]
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Date_In_Readback",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "June"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yea, make note that my wife has a shellfish allergy too, I want to make sure she doesn't get sick."
            }
          },
          {
            "expectation": {
              "note": "Check_SetSpecialRequests_Called",
              "toolCall": {
                "tool": "set_special_requests"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Times_Shown_After_Confirm",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "PM"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "7:30 PM"
            }
          },
          {
            "expectation": {
              "note": "Check_SetSelectedTime_Called",
              "toolCall": {
                "tool": "set_selected_time"
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Combined_Readback_Time",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "7:30"
                  }
                ]
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Combined_Readback_Name",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "Smith"
                  }
                ]
              }
            }
          },
          {
            "expectation": {
              "note": "Check_Combined_Readback_Allergy",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "shellfish"
                  }
                ]
              }
            }
          }
        ]
      },
      {
        "steps": [
          {
            "userInput": {
              "text": "Yes"
            }
          },
          {
            "expectation": {
              "note": "Check_Confirmation_Number",
              "agentResponse": {
                "chunks": [
                  {
                    "text": "BN-"
                  }
                ]
              }
            }
          }
        ]
      }
    ],
    "evaluationExpectations": [
      "No Technical Leakage",
      "Warm Restaurant Host Persona"
    ]
  }
}
