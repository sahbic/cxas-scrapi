      "updated": 1,
      "link": null,
      "locked": false,
      "text": "golden_reservation.yaml\n──────────────────────\nturns:\n  - user: \"Table for 2\"\n    expectations:\n      - tool_called: set_party_size\n      - agent_response: contains \"date\"\n  - user: \"June 20th\"\n    expectations:\n      - tool_called: set_preferred_date\n      - agent_response: contains \"name\"\n──────────────────────\n⚠  INVALID = FAIL if agentResponse missing\nRuns N times · pass rate ≥ threshold",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "e4",
      "originalText": "golden_reservation.yaml\n──────────────────────\nturns:\n  - user: \"Table for 2\"\n    expectations:\n      - tool_called: set_party_size\n      - agent_response: contains \"date\"\n  - user: \"June 20th\"\n    expectations:\n      - tool_called: set_preferred_date\n      - agent_response: contains \"name\"\n──────────────────────\n⚠  INVALID = FAIL if agentResponse missing\nRuns N times · pass rate ≥ threshold",
